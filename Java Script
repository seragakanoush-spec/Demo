// 2. DYNAMIC RENDERING
// This function builds the HTML for our projects instantly when the page loads.
function renderProjects() {
  const grid = document.getElementById('projectGrid');
  
  if (!grid) return; // Safety check

  const htmlString = portfolioData.map(project => `
    <article class="project-card">
      <img src="${project.image}" alt="${project.title}" class="project-image" loading="lazy">
      <div class="project-meta">
        <h3>${project.title}</h3>
        <span style="color: var(--color-text-muted)">${project.category}</span>
      </div>
    </article>
  `).join('');

  grid.innerHTML = htmlString;
}

// 3. SCROLL ANIMATIONS (Intersection Observer)
// This is a highly performant way to detect when an element enters the screen to trigger an animation.
function initScrollAnimations() {
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.15 // Triggers when 15% of the element is visible
  };

  const observer = new IntersectionObserver((entries, observer) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        // Add the CSS class that fades it in
        entry.target.classList.add('is-visible');
        // Stop observing once it's visible so the animation only happens once
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  // Grab all the cards we just created and observe them
  const cards = document.querySelectorAll('.project-card');
  cards.forEach(card => observer.observe(card));
}

// 4. INITIALIZE APP
// Wait for the DOM to be fully loaded before running our scripts
document.addEventListener('DOMContentLoaded', () => {
  renderProjects();
  // Small delay to ensure the DOM has updated before observing
  setTimeout(initScrollAnimations, 100); 
});
